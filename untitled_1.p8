pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
points={}

function _init()
	addpoint(32,32,7)
	addpoint(64,64,9)
end

function _update()
	for p in all(points) do
		p.x+=cos(time())*-1
		p.y+=sin(time())
	end
end

function _draw()
	cls()
	for p in all(points) do
		pset(p.x,p.y,p.c)
	end
end
-->8
function addpoint(px,py,pc)
	point={
		x=px,
		y=py,
		c=pc
	}
	add(points,point)
	return point
end
