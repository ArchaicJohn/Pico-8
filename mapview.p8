pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
x=0
y=0
max_x=112
max_y=48
spd=1

function _update()
	doinput()
	
	if x<0 then
		x=0
	elseif x>max_x then
		x=max_x
	end

	if y<0 then
		y=0
	elseif y>max_y then
		y=max_y
	end
	
end

function _draw()
	cls()
	map(x,y)
end

function doinput()
	if btn(⬅️) then
		x-=spd			
	elseif btn(➡️) then
		x+=spd
	end
	
	if btn(⬆️) then
		y-=spd
	elseif btn(⬇️) then
		y+=spd
	end
end
