pico-8 cartridge // http://www.pico-8.com
version 42
__lua__


function _init()
	p={
		s=1,
		x=32,
		y=38
	}
end

function _update()
	--this works but needs to be changed to check
	--bounds not just x,y positions with padding
	if btn(⬅️) then
		if fmget(p.x,p.y+4)==1 then
			p.x-=1
		end
	end
	if btn(➡️) then
		if fmget(p.x+8,p.y+4)==1 then
			p.x+=1
		end
	end
	if btn(⬆️) then
		if fmget(p.x+4,p.y)==1 then
			p.y-=1
		end
	end
	if btn(⬇️) then
		if fmget(p.x+4,p.y+9)==1 then
			p.y+=1
		end
	end
end

function _draw()
	cls()
	map()
	spr(p.s,p.x,p.y)
end

function fmget(x,y)
	return fget(mget(x/8,y/8))
end
