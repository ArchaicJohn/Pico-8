pico-8 cartridge // http://www.pico-8.com
version 43
__lua__



function _draw()
	cls()
	drawbubble(1,32,32)
	drawbubble(2,42,32)
	drawbubble(3,52,32)
end

function drawbubble(t,x,y)
	spr(57,x,y)
	
	if (t>1) then
		local b=0
		if t==2 then
			b=11
		elseif t==3 then
			b=12
			--to get water balloon recolour fire with pal
		end
		spr(b,x,y)
	end
end
