pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
sp={
		down=27,
		right=28,
		up=29,
		upblock=45,
		left=30
	}
	
shield={
		ud=25,
		udb=42,
		lr=26
	}

function _draw()
	cls()
 --spr(12,45,64)

	--idle
	--down
	spr(sp.down,64,64)
	spr(shield.ud,63,64)
	
	--right, draw shield first
	spr(shield.udb,82,64)
	spr(sp.right,76,64)
	
	--up	
	spr(sp.up,88,64)
	spr(shield.ud,89,64,1,1,true,false)
	
	--left
	spr(sp.left,100,64)
	spr(shield.lr,105,64)
	
	--shield up
	--down
	spr(sp.down,64,76)
	spr(shield.lr,64,76)
	
	--right
	spr(sp.right,76,76)
	spr(shield.ud,77,76,1,1,true,false)

	--up, draw shield first
	spr(shield.udb,93,74)
	spr(sp.upblock,88,76)

	--left
	spr(sp.left,101,76)
	spr(shield.ud,100,76)

end


