pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--tilemap move flags
--by archaicjohn

--[[
	flag values for blocked 
	exits per tile:
	l = 1
	r = 2
	u = 3
	d = 4
	ul = 5
	ur = 6
	dl = 7
	dr = 8
	lr = 9
	ud = 10
]]

px,py=16,32

function _update()
	dx,dy=0,0
	
	if btnp(⬅️) then
		dx-=8
	elseif btnp(➡️) then
		dx+=8
	elseif btnp(⬆️) then
		dy-=8
	elseif btnp(⬇️) then
		dy+=8
	end
	
	if not checktileflags(px,py,dx,dy) then
		px+=dx
		py+=dy
	end
end

function _draw()
	cls()
	map()
	spr(1,px,py)
end

function checktileflags(tx,ty,mx,my)
	block=false
	cur_tile=mget(tx/8,ty/8)
	next_tile=mget((px+mx)/8,(py+my)/8)

	--moving left
	if mx<0 then
		if fget(cur_tile)==1 or 
					fget(cur_tile)==5 or
					fget(cur_tile)==7 or
					fget(cur_tile)==9 or
					fget(next_tile)==2 or
					fget(next_tile)==6 or
					fget(next_tile)==8	or
					fget(next_tile)==9	then
			block=true
		end
		--moving right
	elseif mx>0 then
		if fget(cur_tile)==2 or 
					fget(cur_tile)==6 or
					fget(cur_tile)==8 or
					fget(cur_tile)==9 or
					fget(next_tile)==1 or
					fget(next_tile)==5 or
					fget(next_tile)==7 or
					fget(next_tile)==9 then
			block=true
		end
	end
	
	--moving up
	if my<0 then
		if fget(cur_tile)==3 or 
					fget(cur_tile)==5 or
					fget(cur_tile)==6 or
					fget(cur_tile)==10 or
					fget(next_tile)==4 or
					fget(next_tile)==7 or
					fget(next_tile)==8	then
			block=true
		end
	--moving down
	elseif my>0 then
		if fget(cur_tile)==4 or 
					fget(cur_tile)==7 or
					fget(cur_tile)==8 or
					fget(cur_tile)==10 or
					fget(next_tile)==3 or
					fget(next_tile)==5 or
					fget(next_tile)==6	then
			block=true
		end
	end
	
	return block
end
