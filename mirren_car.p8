pico-8 cartridge // http://www.pico-8.com
version 42
__lua__

function _init()
	player={
		sp=1,
		x=32,
		y=32,
		x1=32+8,
		y1=32+8,
		flipx=false,
		flipy=false,
		spd=0,
		spdmax=3,
		lifecur=1,
		lifemax=3,
		accel=0.15,
		decel=0.1,
		brake=0.25,
		dir="right"
	}
end

function _update()
	moveplayer()
	followplayer()
end

function _draw()
	cls()
	map()
	drawplayer()
end

function drawplayer()
	spr(player.sp,player.x,player.y,1,1,player.flipx,player.flipy)
end

function moveplayer()
	local dx,dy=0,0
	
	if btn(❎) then
		--accelerate
		player.spd+=player.accel
		player.spd=min(player.spd,player.spdmax)
	elseif btn(🅾️) then
		--brake
		player.spd-=player.brake
		player.spd=max(player.spd,0)
	else
		--decelerate
		player.spd-=player.decel
		player.spd=max(player.spd,0)
	end

	if btn(⬅️) then
		player.dir="left"	
	elseif btn(➡️) then
		player.dir="right"
	elseif btn(⬆️) then
		player.dir="up"
	elseif btn(⬇️) then
		player.dir="down"
	end
	
	if player.dir=="left" then
		dx-=player.spd
		player.sp=1
		player.flipx=true
		player.flipy=false
		
		if checkmapsolid(player.x+dx,player.y) or
		   checkmapsolid(player.x+dx,player.y+8) then
			dx=0	
		end
	elseif player.dir=="right" then
		dx+=player.spd
		player.sp=1
		player.flipx=false
		player.flipy=false
		
		if checkmapsolid(player.x+8+dx,player.y) or
		   checkmapsolid(player.x+8+dx,player.y+8) then
			dx=0	
		end
	elseif player.dir=="up" then
		dy-=player.spd
		player.sp=4
		player.flipx=false
		player.flipy=false

		if checkmapsolid(player.x,player.y+dy) or
		   checkmapsolid(player.x+8,player.y+dy) then
			dy=0	
		end
	elseif player.dir=="down" then
		dy+=player.spd
		player.sp=5
		player.flipx=false
		player.flipy=false
	
		if checkmapsolid(player.x,player.y+dy) or
		   checkmapsolid(player.x+8,player.y+8+dy) then
			dy=0	
		end
	end

	player.x+=dx
	player.x1=player.x+8
	player.y+=dy
	player.y1=player.y+8
end


function followplayer()
	camera(player.x-64,player.y-64)
end
-->8
--utils

function overlap(a,b)
	if (a.x>b.x1 or 
		a.y>b.y1 or 
		a.x1<b.x or 
		a.y1<b.y) then
			return false
	end	
	return true
end

function fmget(x,y)
	return fget(mget(x/8,y/8))
end

function checkmapsolid(x,y)
	return fmget(x,y)==1
end

