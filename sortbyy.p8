pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
things={}

function _init()
	cls()
	for i=1,10 do
		local t={}
		t.y=rnd(128)
		t.y=flr(t.y)
		add(things,t)
	end

	sort(things)
end

function sort(a)
	printyvals(a)
	print(" ")
	sortbyy(a)
	printyvals(a)
end

function printyvals(a)
	for i=1,#a do
		print(a[i].y)
	end
end

function sortbyy(a)
 for i=1,#a do
  local j=i
  while j>1 and a[j-1].y>a[j].y do
   a[j],a[j-1]=a[j-1],a[j]
   j=j-1
  end
 end
end
