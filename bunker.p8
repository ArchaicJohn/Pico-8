pico-8 cartridge // http://www.pico-8.com
version 41
__lua__



function _init()
	build=false

	player={
		x=32,
		y=32,
		s=1
	}
	
	cur={
		x=32,
		y=32,
		s=12
	}
end

function _update()
	--capture input
	local l,r,u,d,bo,bx=btnp(0),btnp(1),btnp(2),btnp(3),btnp(4),btnp(5)
	local dx,dy=0,0
	
	if bx then
		build=not build
		cur.x=player.x
		cur.y=player.y
	end
		
	if l then
		dx-=8
	elseif r then
		dx+=8
	end
	
	if u then
		dy-=8
	elseif d then
		dy+=8
	end
	
	--apply input
	if not build then
		player.x+=dx
		player.y+=dy
	else
		cur.x+=dx
		cur.y+=dy
	end
end

function _draw()
	cls()
	debugprint()
	
	if build then
		drawcursor()
	end
	drawplayer()	
	--[[
	local s=50+time()%2
	spr(s,32,32)
	spr(s,40,32)	
	]]--
end

function debugprint()
	print("build: "..(build and 'true' or 'false'))
end

function drawcursor()
	spr(cur.s,cur.x,cur.y)
end

function drawplayer()
	spr(player.s,player.x,player.y)
end

