pico-8 cartridge // http://www.pico-8.com
version 42
__lua__

cx,cy=0,0

function _init()

end

function _update()
	local l,r,u,d=btn(0),btn(1),btn(2),btn(3)
	
	if l then
		cx-=1
	elseif r then
		cx+=1	
	end

	if u then
		cy-=1
	elseif d then
		cy+=1	
	end
	
	camera(cx,cy)
end

function _draw()
	cls()
	map()

	print("cx: "..peek2(0x5f28),cx,cy)
	print("cy: "..peek2(0x5f2a),cx,6+cy)
end

