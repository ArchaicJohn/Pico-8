pico-8 cartridge // http://www.pico-8.com
version 42
__lua__

player={
	sp=1,
	x=32,
	y=32,
	spd=1
}

gravity=3

function _init()

end

function _update()
	moveplayer()
end

function _draw()
	cls()
 map()
	spr(player.sp,player.x,player.y)
end

function moveplayer()
	
	local dx,dy=0,0
	
	--handle input
	if btn(⬅️) then
		dx-=player.spd
	elseif btn(➡️) then
		dx+=player.spd
	end
	
	--check for solid tiles
	if(not checksolid(player.x,player.y,8,8)) then
		dy+=gravity
	end
	
	--apply movement
	player.x+=dx
	player.y+=dy
	
	--keep player on screen
	if (player.x<=0) then
		player.x=0
	elseif (player.x+8>127) then
		player.x=120
	end
	
	--reset y position if off screen
	if (player.y>=128) then
		player.y=0
	end
end

-->8
--utils

function fmget(x,y)
	return fget(mget(x/8,y/8))
end

function checksolid(x,y,w,h)
	if (fget(mget(x/8,(y+h)/8)) == 1 or
		fget(mget((x+w)/8,(y+h)/8)) == 1) then 
			return true
	end
	return false
end
