pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

#include utils.lua

--sprite flags
-- 1 = map collision

entities={}
-- entity types
-- 1 = mob
-- 2 = pickup

gstate=1
-- 0=title
-- 1=gameplay
-- 2=gameover

maxfallspeed=1 --3 feels good

-- TODO: implement a per-tile collision check instead of per pixel
-- need to handle move speed > 1 properly with collision checks

coin={s=48,t=2,w=8,h=8}
p1={s=1,t=1,w=8,h=8,spd=1}

function _init()
	--makeplayer(1,64,32) -- When player starts at different Y (i.e. 40) overlaps with coins break
	player=makeentityobj(p1,64,64)
	player.jumpcounter=0
	player.maxjumptime=5
	player.jumpforce=4

 	-- add coins
	makeentityobj(coin,24,56)
	makeentityobj(coin,24,48)
	makeentityobj(coin,32,64)
	makeentityobj(coin,40,64)	
	makeentityobj(coin,88,64)
	makeentityobj(coin,96,64)
	makeentityobj(coin,104,56)
	makeentityobj(coin,104,48)
end

function _update()
	doinput()
end

function _draw()
	cls()

	map()

	if gstate==1 then
		foreach(entities,drawentity)
	end

	print("x:"..player.x)
	print("y:"..player.y)
	print("state:"..player.state)
	print("jmpctr:"..player.jumpcounter)

end

function doinput()
	if gstate==1 then
		moveplayer()
	end
end

--BUG: Player stops falling when colliding with a wall
function moveplayer()
	local l,r,u,d,bo,bx=btn(0),btn(1),btn(2),btn(3),btn(4),btn(5)
	local movespeed=player.spd
	player.dx,player.dy=0,0
	player.fx=false

	if player.state=="grounded" then
		if not checksolidentity(player) then 
			setstate(player,"falling")
		elseif bx then
			setstate(player,"jumping")
		end
	elseif player.state=="falling" then
		--BUG: because fall speed can be greater than 1, we need to look ahead further to avoid penetrating the ground OR correct ground penetration
		if not checksolidentity(player) then 
			--TODO: gradually increase fall speed over time on a curve to get slower initial acceleration that increases the longer you fall until max
			player.dy+=player.fallspeed
			if player.fallspeed < maxfallspeed then
				player.fallspeed+=1
			end
		else
			setstate(player,"grounded")
			player.jumpcounter=0
		end
	elseif player.state=="jumping" then
		if player.jumpcounter < player.maxjumptime then
			--TODO: Reduce jump force over time on a curve to get the fast acceleration up with a slower peak before falling
			player.dy-=player.jumpforce
			player.jumpcounter+=1
		else
			setstate(player,"falling")
		end
	end

	-- will need a function to check each position along the player's direction + movespeed (or fall speed) in order to tell when we're colliding
	-- if something is hit then dx/dy are +/- movespeed minus the distance to the object in that direction
	if l then
		if not (fmget((player.x-1),player.y) == 1 or
				fmget(player.x,player.y+(player.h-1)) == 1) then
				player.dx-=movespeed
		end
	elseif r then
		player.fx=true
		if not (fmget(player.x+player.w,player.y) == 1 or
			fmget(player.x+player.w,player.y+(player.h-1)) == 1) then
			player.dx+=movespeed
		end
	end

	--apply movement
	player.x+=player.dx
	player.x1=player.x+player.w
	player.y+=player.dy
	player.y1=player.y+player.w

	--check if player is overlapping another entity
	for e in all(entities) do
		if(overlap(player,e)) then
			--pickup check
			if e.type==2 then
				del(entities,e)
				sfx(0)
			end
  		end
	end
end

-->8
--entity

function makeentity(s,t,x,y,w,h,spd)
	e={	s=s,
		type=t,
		x=x,y=y,
		w=w,h=h,
		x1=x+w,y1=y+h,
		fx=false,
		spd=spd,
		dx=0,dy=0,
		state="falling",
		fallspeed=1
	}
	return e
end

function makeentityobj(obj,x,y,spd)
	local e=makeentity(obj.s,obj.t,x,y,obj.w,obj.h,obj.spd)
	add(entities,e)
	return e
end

function drawentity(e)
	spr(e.s,e.x,e.y,1,1,e.fx,e.fy)
end

function setstate(e,st)
	e.state=st
end


